@model IEnumerable<LibraryApp.Models.Book>

@{
    ViewData["Title"] = "Książki";
}

<h2>Książki</h2>
<a asp-action="Create" class="btn btn-primary mb-3">Dodaj książkę</a>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Tytuł</th>
            <th>ISBN</th>
            <th>Rok wydania</th>
            <th>Autor</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var book in Model)
        {
            <tr>
                <td>@book.Title</td>
                <td>@book.Isbn</td>
                <td>@book.PublishedYear</td>
                <td>@book.Author.FullName</td>
                <td>
                    <a asp-action="Details" asp-route-id="@book.Id" class="btn btn-sm btn-outline-secondary">Szczegóły</a>
                </td>
            </tr>
        }
    </tbody>
</table>
